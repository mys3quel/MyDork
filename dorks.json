{
  "catdefs": [
    { "id": "discovery", "icon": "🔍", "name": "Subdomain & Certificate Discovery" },
    { "id": "github", "icon": "🐙", "name": "GitHub Code Search" },
    { "id": "google_dirs", "icon": "📂", "name": "Google — Directories & Exposed Files" },
    { "id": "google_panels", "icon": "🕵️", "name": "Google — Panels, APIs & Dev Envs" },
    { "id": "google_leaks", "icon": "🩺", "name": "Google — Secrets & Info Leaks" },
    { "id": "yandex", "icon": "🇷🇺", "name": "Yandex — Same Dorks, Different Index" },
    { "id": "shodan", "icon": "🛰️", "name": "Shodan, Censys & URLScan" },
    { "id": "recon", "icon": "🌐", "name": "External Recon Sources" }
  ],

  "dorks": {
    "discovery": [
      { "title": "CRT.sh JSON", "url": "https://crt.sh/?q={wc}{domain}&output=json", "dot": "purple" },
      { "title": "CRT.sh HTML", "url": "https://crt.sh/?q={wc}{domain}", "dot": "purple" },
      { "title": "CRT.sh (dedup)", "url": "https://crt.sh/?q={wc}{domain}&deduplicate=Y", "dot": "purple" },
      { "title": "CRT.sh (no expired)", "url": "https://crt.sh/?q={wc}{domain}&exclude=expired", "dot": "purple" },
      { "title": "RapidDNS", "url": "https://rapiddns.io/subdomain/{domain}?full=1", "dot": "blue" },
      { "title": "AlienVault OTX", "url": "https://otx.alienvault.com/indicator/domain/{domain}", "dot": "blue" },
      { "title": "SecurityTrails", "url": "https://securitytrails.com/domain/{domain}", "dot": "blue" },
      { "title": "DNSDumpster", "url": "https://dnsdumpster.com/", "dot": "blue" }
    ],

    "github": [
      { "title": "Domain mention", "query": "\"{domain}\"", "type": "github", "dot": "green", "needs_org": true },
      { "title": ".env files", "query": "path:**/.env /^[A-Z]{2,}_[A-Z_]{2,}=/", "type": "github", "dot": "green", "needs_org": true },
      { "title": ".npmrc (npm token)", "query": "path:**/.npmrc /_authToken/", "type": "github", "dot": "green", "needs_org": true },
      { "title": ".pypirc (PyPI token)", "query": "path:**/.pypirc /password/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Docker config.json", "query": "path:**/config.json /\"auth\"/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Terraform tfvars", "query": "path:**/terraform.tfvars /password|secret|token|key/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "GitHub Actions workflows", "query": "path:**/.github/workflows /secrets|token|password/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "GitLab CI (gitlab-ci.yml)", "query": "path:**/.gitlab-ci.yml /SECRET|PASSWORD|TOKEN/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "k8s secrets.yaml", "query": "path:**/secret.yaml /[a-zA-Z0-9+/=]{40,}/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Ansible vault", "query": "path:**/vault.yml", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Ansible secrets", "query": "path:**/secrets.yml", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Private keys — PEM", "query": "/-----BEGIN.*PRIVATE KEY-----/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Private keys — OpenSSH", "query": "\"-----BEGIN OPENSSH PRIVATE KEY-----\"", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Google API keys", "query": "/AIza[0-9A-Za-z_-]{35}/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "AWS access keys (AKIA)", "query": "/AKIA[0-9A-Z]{16}/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "AWS secret keys", "query": "/aws_secret_access_key|aws_access_key_id/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "GitHub tokens (ghp_)", "query": "/ghp_[0-9a-zA-Z]{36}/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Slack tokens (xoxb/xoxp)", "query": "/xox[baprs]-[0-9a-zA-Z-]+/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Stripe live keys", "query": "/sk_live_[0-9a-zA-Z]{24}/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "JWT tokens", "query": "/eyJ[a-zA-Z0-9_-]{10,}\\\\.eyJ/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Connection strings (DB/Redis)", "query": "/jdbc:|mongodb://|redis://|postgres://|mysql:///", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Password/secrets assignments", "query": "/(password|secret|passwd)\\s*=\\s*['\"][^'\"]{4,}/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Bash history files", "query": "path:**/.bash_history", "type": "github", "dot": "green", "needs_org": true },
      { "title": "All .pem files", "query": "path:**/*.pem", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Dockerfiles with ENV", "query": "path:**/Dockerfile /ENV/", "type": "github", "dot": "green", "needs_org": true },
      { "title": "Config files w/ creds", "query": "path:**/config language:yaml /password|secret|token/", "type": "github", "dot": "green", "needs_org": true }
    ],

    "google_dirs": [
      { "title": "Directory listing (root)", "query": "intitle:\"index of /\"", "type": "google", "dot": "orange" },
      { "title": "Directory listing — admin", "query": "intitle:\"index of\" inurl:admin", "type": "google", "dot": "orange" },
      { "title": "Directory listing — backup", "query": "intitle:\"index of\" inurl:backup", "type": "google", "dot": "orange" },
      { "title": "Exposed .env files", "query": "ext:env", "type": "google", "dot": "orange" },
      { "title": "Exposed SQL dumps", "query": "ext:sql \"INSERT INTO\"", "type": "google", "dot": "orange" },
      { "title": "Exposed SQL dumps (pg)", "query": "ext:sql \"CREATE TABLE\"", "type": "google", "dot": "orange" },
      { "title": "Log files — access", "query": "intitle:\"index of\" \"access.log\"", "type": "google", "dot": "orange" },
      { "title": "Log files — error", "query": "intitle:\"index of\" \"error.log\"", "type": "google", "dot": "orange" },
      { "title": "Log files — debug", "query": "intitle:\"index of\" \"debug.log\"", "type": "google", "dot": "orange" },
      { "title": "Log files (all ext:log)", "query": "ext:log", "type": "google", "dot": "orange" },
      { "title": "Backup files (.bak)", "query": "ext:bak", "type": "google", "dot": "orange" },
      { "title": "Backup archives (.tar.gz)", "query": "ext:tar.gz", "type": "google", "dot": "orange" },
      { "title": "Backup archives (.zip)", "query": "ext:zip", "type": "google", "dot": "orange" },
      { "title": "Config files (.conf)", "query": "ext:conf", "type": "google", "dot": "orange" },
      { "title": "YAML configs (.yml/.yaml)", "query": "ext:yml OR ext:yaml", "type": "google", "dot": "orange" },
      { "title": "JSON files", "query": "ext:json \"api_key\" OR \"password\" OR \"secret\"", "type": "google", "dot": "orange" },
      { "title": "PEM certificate files", "query": "ext:pem", "type": "google", "dot": "orange" },
      { "title": "Private key files (.key)", "query": "ext:key", "type": "google", "dot": "orange" },
      { "title": "Exposed .git/config", "query": "intitle:\"index of\" \".git/config\"", "type": "google", "dot": "orange" },
      { "title": "Text files with passwords", "query": "ext:txt intext:\"password\"", "type": "google", "dot": "orange" }
    ],

    "google_panels": [
      { "title": "Login pages", "query": "inurl:login", "type": "google", "dot": "teal" },
      { "title": "Admin panels", "query": "inurl:admin", "type": "google", "dot": "teal" },
      { "title": "Dashboards", "query": "inurl:dashboard", "type": "google", "dot": "teal" },
      { "title": "Signup / Register", "query": "inurl:signup OR inurl:register", "type": "google", "dot": "teal" },
      { "title": "OAuth / SSO endpoints", "query": "inurl:oauth OR inurl:saml OR inurl:openid", "type": "google", "dot": "teal" },
      { "title": "GraphQL endpoints", "query": "inurl:graphql", "type": "google", "dot": "teal" },
      { "title": "Swagger / OpenAPI docs", "query": "inurl:swagger OR inurl:api-docs", "type": "google", "dot": "teal" },
      { "title": "OpenAPI spec files", "query": "inurl:openapi.json OR inurl:swagger.json", "type": "google", "dot": "teal" },
      { "title": "REST API paths", "query": "inurl:/api/v1 OR inurl:/api/v2", "type": "google", "dot": "teal" },
      { "title": "Spring Boot Actuators", "query": "inurl:actuator", "type": "google", "dot": "teal" },
      { "title": "Jira instances", "query": "inurl:jira intitle:\"System Dashboard\"", "type": "google", "dot": "teal" },
      { "title": "Confluence", "query": "inurl:confluence", "type": "google", "dot": "teal" },
      { "title": "Jenkins CI", "query": "inurl:jenkins intitle:\"Dashboard [Jenkins]\"", "type": "google", "dot": "teal" },
      { "title": "GitLab self-hosted", "query": "inurl:gitlab intitle:\"Sign in\"", "type": "google", "dot": "teal" },
      { "title": "PHP info page", "query": "intitle:\"phpinfo()\"", "type": "google", "dot": "teal" },
      { "title": "Status / Health endpoints", "query": "inurl:status OR inurl:health OR inurl:healthcheck", "type": "google", "dot": "teal" },
      { "title": "Debug endpoints", "query": "inurl:debug OR inurl:trace", "type": "google", "dot": "teal" },
      { "title": "Console pages", "query": "inurl:console intitle:\"Management\"", "type": "google", "dot": "teal" },
      { "title": "Dev environments", "query": "inurl:dev.", "type": "google", "dot": "teal" },
      { "title": "Staging environments", "query": "inurl:staging.", "type": "google", "dot": "teal" },
      { "title": "UAT environments", "query": "inurl:uat.", "type": "google", "dot": "teal" },
      { "title": "Beta environments", "query": "inurl:beta.", "type": "google", "dot": "teal" },
      { "title": "Sandbox environments", "query": "inurl:sandbox.", "type": "google", "dot": "teal" },
      { "title": "Demo environments", "query": "inurl:demo.", "type": "google", "dot": "teal" },
      { "title": "Test environments", "query": "inurl:test.", "type": "google", "dot": "teal" },
      { "title": "Non-WWW subdomains", "query": "-inurl:www", "type": "google", "dot": "teal" },
      { "title": "Well-known URIs", "query": "inurl:.well-known/", "type": "google", "dot": "teal" },
      { "title": "WordPress wp-admin", "query": "inurl:wp-admin", "type": "google", "dot": "teal" }
    ],

    "google_leaks": [
      { "title": "RSA/EC private keys", "query": "\"-----BEGIN RSA PRIVATE KEY-----\" OR \"-----BEGIN EC PRIVATE KEY-----\"", "type": "google", "dot": "red" },
      { "title": "OpenSSH private keys", "query": "\"-----BEGIN OPENSSH PRIVATE KEY-----\"", "type": "google", "dot": "red" },
      { "title": "AWS access keys", "query": "intext:\"AKIA\" intext:\"aws_access_key\"", "type": "google", "dot": "red" },
      { "title": "MongoDB connection URIs", "query": "intext:\"mongodb://\" OR intext:\"mongodb+srv://\"", "type": "google", "dot": "red" },
      { "title": "Sentry DSNs", "query": "intext:\"sentry.io\" intext:\"http\"", "type": "google", "dot": "red" },
      { "title": "Stack traces with paths", "query": "\"stack trace\" intext:\"/var/www/\" OR intext:\"/home/\" OR intext:\"at \"", "type": "google", "dot": "red" },
      { "title": "Oracle DB errors", "query": "\"ORA-\" \"line\"", "type": "google", "dot": "red" },
      { "title": "SQL errors (SQLSTATE)", "query": "\"SQLSTATE\" intext:\"error\"", "type": "google", "dot": "red" },
      { "title": "OAuth client secrets", "query": "intext:\"client_secret\" ext:json OR ext:yml OR ext:env", "type": "google", "dot": "red" },
      { "title": "Django DEBUG + SECRET_KEY", "query": "intext:\"DEBUG = True\" intext:\"SECRET_KEY\"", "type": "google", "dot": "red" },
      { "title": "Laravel APP_KEY", "query": "intext:\"APP_KEY\" intext:\"base64\"", "type": "google", "dot": "red" },
      { "title": "Firebase configs", "query": "intext:\"firebaseio.com\" ext:json OR ext:js", "type": "google", "dot": "red" },
      { "title": "Supabase keys", "query": "intext:\"supabase\" intext:\"anon\" OR intext:\"service_role\"", "type": "google", "dot": "red" },
      { "title": "SMTP credentials", "query": "intext:\"smtp.gmail.com\" intext:\"password\" OR intext:\"smtp.office365.com\"", "type": "google", "dot": "red" },
      { "title": "Database passwords in config", "query": "intext:\"DB_PASSWORD\" intext:\"DB_USER\" ext:env OR ext:conf", "type": "google", "dot": "red" },
      { "title": "FTP credentials", "query": "intext:\"FTP_PASSWORD\" OR intext:\"ftp_password\"", "type": "google", "dot": "red" },
      { "title": "Slack webhooks", "query": "intext:\"hooks.slack.com\" ext:json OR ext:env OR ext:js", "type": "google", "dot": "red" },
      { "title": "JWT signing secrets", "query": "intext:\"JWT_SECRET\" OR intext:\"jwt_secret\" ext:env OR ext:yml", "type": "google", "dot": "red" },
      { "title": "Backup SQL with data", "query": "ext:sql \"INSERT INTO\" \"VALUES\"", "type": "google", "dot": "red" },
      { "title": "Log files with passwords", "query": "ext:log intext:\"password\"", "type": "google", "dot": "red" }
    ],

    "yandex": [
      { "title": "Login pages", "query": "inurl:login", "type": "yandex", "dot": "teal" },
      { "title": "Admin panels", "query": "inurl:admin", "type": "yandex", "dot": "teal" },
      { "title": "Exposed .env files", "query": "ext:env", "type": "yandex", "dot": "orange" },
      { "title": "Exposed SQL dumps", "query": "ext:sql \"INSERT INTO\"", "type": "yandex", "dot": "orange" },
      { "title": "Log files", "query": "ext:log", "type": "yandex", "dot": "orange" },
      { "title": "Backup files", "query": "ext:bak OR ext:tar.gz", "type": "yandex", "dot": "orange" },
      { "title": "YAML config files", "query": "ext:yml OR ext:yaml", "type": "yandex", "dot": "orange" },
      { "title": "JSON configs w/ secrets", "query": "ext:json intext:\"password\" OR intext:\"secret\" OR intext:\"key\"", "type": "yandex", "dot": "orange" },
      { "title": "Dev environments", "query": "inurl:dev.", "type": "yandex", "dot": "teal" },
      { "title": "Staging environments", "query": "inurl:staging.", "type": "yandex", "dot": "teal" },
      { "title": "Sandbox environments", "query": "inurl:sandbox.", "type": "yandex", "dot": "teal" },
      { "title": "Test environments", "query": "inurl:test.", "type": "yandex", "dot": "teal" },
      { "title": "PHP info pages", "query": "intitle:\"phpinfo()\"", "type": "yandex", "dot": "red" },
      { "title": "Spring Boot Actuators", "query": "inurl:actuator", "type": "yandex", "dot": "teal" },
      { "title": "Swagger / OpenAPI docs", "query": "inurl:swagger OR inurl:api-docs", "type": "yandex", "dot": "teal" },
      { "title": "RSA private keys", "query": "\"-----BEGIN RSA PRIVATE KEY-----\"", "type": "yandex", "dot": "red" },
      { "title": "OpenSSH private keys", "query": "\"-----BEGIN OPENSSH PRIVATE KEY-----\"", "type": "yandex", "dot": "red" },
      { "title": "Stack traces", "query": "\"stack trace\"", "type": "yandex", "dot": "red" },
      { "title": "Django DEBUG mode", "query": "\"DEBUG = True\" \"SECRET_KEY\"", "type": "yandex", "dot": "red" },
      { "title": "Non-WWW subdomains", "query": "-inurl:www", "type": "yandex", "dot": "teal" }
    ],

    "shodan": [
      { "title": "Shodan wildcard", "url": "https://www.shodan.io/search?query=hostname%3A*.{domain}", "dot": "pink" },
      { "title": "Shodan exact", "url": "https://www.shodan.io/search?query=hostname%3A{domain}", "dot": "pink" },
      { "title": "Shodan SSL certs", "url": "https://www.shodan.io/search?query=ssl%3A{domain}", "dot": "pink" },
      { "title": "Censys certificates", "url": "https://search.censys.io/certificates?q={domain}", "dot": "pink" },
      { "title": "Censys hosts", "url": "https://search.censys.io/hosts?q={domain}", "dot": "pink" },
      { "title": "URLScan.io search", "url": "https://urlscan.io/search/#page.domain:*{domain}*", "dot": "pink" }
    ],

    "recon": [
      { "title": "Wayback CDX (all URLs)", "url": "https://web.archive.org/cdx/search/cdx?url=*.{domain}/*&output=text&fl=original&collapse=urlkey", "dot": "blue" },
      { "title": "Wayback URL list (more)", "url": "https://web.archive.org/cdx/search/cdx?url=*.{domain}/*&output=text&fl=original,timestamp,status,length,mimetype&collapse=urlkey", "dot": "blue" },
      { "title": "Wayback Calendar", "url": "https://web.archive.org/web/*/{domain}/*", "dot": "blue" },
      { "title": "BuiltWith", "url": "https://builtwith.com/{domain}", "dot": "blue" },
      { "title": "Wappalyzer", "url": "https://www.wappalyzer.com/lookup/{domain}", "dot": "blue" },
      { "title": "GrayHatWarfare S3 buckets", "url": "https://buckets.grayhatwarfare.com/results/{domain}", "dot": "blue" },
      { "title": "CommonCrawl (latest)", "url": "https://index.commoncrawl.org/CC-MAIN-2025-22-index?url=*.{domain}/*&output=json", "dot": "blue" }
    ]
  }
}
